{%- comment -%}
Debug / inspection snippet for Shopify Search & Discovery filters.
Outputs a JSON-like structure plus a simple HTML table to visualize filter data.
Safe to include on dev only. Remove before production.
Accepted contexts: collection, search, or an injected `results` object.
{%- endcomment -%}

{%- assign results = results | default: collection | default: search -%}
<h2>Filters Debug</h2>
{%- if results and results.filters and results.filters != empty -%}
  <pre style="white-space:pre; font-size:12px; line-height:1.3; overflow:auto; max-height:600px; border:1px solid #ddd; padding:1rem; background:#fafafa" data-filter-debug>
{
  "filters": [
  {%- for filter in results.filters -%}
    {
      "index": {{ forloop.index0 }},
      "type": {{ filter.type | json }},
      "label": {{ filter.label | json }},
      "param_name": {{ filter.param_name | json }},
      "operator": {{ filter.operator | default: '' | json }},
      "presentation": {{ filter.presentation | default: 'text' | json }},
      "active_values_count": {{ filter.active_values.size }},
      {%- if filter.type == 'price_range' -%}
      "price": {
        "min_value": {%- if filter.min_value.value != nil -%}{{ filter.min_value.value }}{%- else -%}null{%- endif -%},
        "max_value": {%- if filter.max_value.value != nil -%}{{ filter.max_value.value }}{%- else -%}null{%- endif -%},
        "range_max": {{ filter.range_max }}
      },
      {%- endif -%}
      "values": [
        {%- for value in filter.values -%}
        {
          "index": {{ forloop.index0 }},
          "label": {{ value.label | json }},
          "value": {{ value.value | json }},
          "param_name": {{ value.param_name | json }},
          "count": {{ value.count }},
          "active": {{ value.active }},
          "url_to_add": {{ value.url_to_add | json }},
          "url_to_remove": {{ value.url_to_remove | json }},
          {%- if value.image -%}
          "image": {
            "src": {{ value.image | image_url: width: 100 | json }},
            "alt": {{ value.alt | json }}
          }{%- if value.swatch -%},{%- endif -%}
          {%- endif -%}
          {%- if value.swatch -%}
          "swatch": {
            {%- if value.swatch.image -%}"image": {{ value.swatch.image | image_url: width: 40 | json }}{%- if value.swatch.color -%},{%- endif -%}{%- endif -%}
            {%- if value.swatch.color -%}"color": {{ value.swatch.color | json }}{%- endif -%}
          }
          {%- endif -%}
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      "active_values": [
        {%- for av in filter.active_values -%}
        {
          "label": {{ av.label | json }},
          "value": {{ av.value | json }},
          "param_name": {{ av.param_name | json }},
          "url_to_remove": {{ av.url_to_remove | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      "remove_all_url": {{ filter.url_to_remove | json }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
  ]
}
  </pre>

  <h3>Readable Table</h3>
  <style>
    table.filter-debug{border-collapse:collapse; width:100%; font-size:12px; margin-bottom:2rem}
    table.filter-debug th,table.filter-debug td{border:1px solid #ccc; padding:4px 6px; vertical-align:top; text-align:left}
    table.filter-debug th{background:#f0f0f0}
    table.filter-debug code{white-space:pre-wrap; word-break:break-word}
    .chip{display:inline-block; background:#eee; padding:2px 6px; margin:2px; border-radius:12px; font-size:11px}
    .chip.active{background:#d1f5d1}
    .chip.disabled{opacity:.4}
  </style>
  <table class="filter-debug">
    <thead>
      <tr>
        <th>#</th>
        <th>Type</th>
        <th>Label</th>
        <th>Param</th>
        <th>Presentation</th>
        <th>Operator</th>
        <th>Active Values</th>
        <th>All Values (label [count])</th>
        <th>Remove All URL</th>
      </tr>
    </thead>
    <tbody>
      {%- for filter in results.filters -%}
        <tr>
          <td>{{ forloop.index0 }}</td>
          <td><code>{{ filter.type }}</code></td>
          <td>{{ filter.label }}</td>
          <td><code>{{ filter.param_name }}</code></td>
          <td>{{ filter.presentation | default: 'text' }}</td>
            <td>{{ filter.operator }}</td>
          <td>
            {%- for av in filter.active_values -%}
              <span class="chip active">{{ av.label }}</span>
            {%- else -%}
              <span style="color:#888">None</span>
            {%- endfor -%}
          </td>
          <td style="max-width:320px">
            {%- if filter.type == 'price_range' -%}
              <code>min: {%- if filter.min_value.value != nil -%}{{ filter.min_value.value }}{%- else -%}∅{%- endif -%}, max: {%- if filter.max_value.value != nil -%}{{ filter.max_value.value }}{%- else -%}∅{%- endif -%} (range_max: {{ filter.range_max }})</code>
            {%- else -%}
              {%- for value in filter.values -%}
                <span class="chip{% if value.active %} active{% endif %}{% if value.count == 0 and value.active == false %} disabled{% endif %}" title="param={{ value.param_name }} value={{ value.value }} count={{ value.count }}">{{ value.label }} [{{ value.count }}]</span>
              {%- endfor -%}
            {%- endif -%}
          </td>
          <td><code style="word-break:break-all">{{ filter.url_to_remove }}</code></td>
        </tr>
      {%- endfor -%}
    </tbody>
  </table>
{%- else -%}
  <p>No filters available in this context.</p>
{%- endif -%}
